# Supabase — copy to .env.local
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: public URL of the site (used in sitemap / metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: nomor WhatsApp (hanya digit, contoh 6281234567890). Jika kosong, dipakai contact_phone dari site config.
NEXT_PUBLIC_WHATSAPP_NUMBER=
